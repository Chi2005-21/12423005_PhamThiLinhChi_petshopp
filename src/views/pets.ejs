<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-4">
    <h2>Pets</h2>
    <div class="row">
        <% pets.forEach(p => { %>
        <div class="col-md-4">
            <div class="card mb-3">
                <img src="https://placehold.co/300x200" class="card-img-top">
                <div class="card-body">
                    <h5><%= p.name %></h5>
                    <p><%= p.breed %></p>
                    <p><b><%= p.price %> VND</b></p>

                    <a href="/products/pet/<%= p.pet_id %>" class="btn btn-info btn-sm">Detail</a>
                    <a href="/cart/add/<%= p.pet_id %>" class="btn btn-success btn-sm">Add</a>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
</div>

</body>
</html>